{
  "name": "qualitaetskontrolle-rfid-qr",
  "version": "1.0.0",
  "description": "RFID Login & QR Qualitätskontrolle System für Shirtful - Zweimaliges Scannen mit automatischem Session-Abschluss",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --debug",
    "start:gpu-safe": "electron . --disable-gpu --disable-gpu-compositing --force-cpu-draw",
    "start:minimal": "electron . --disable-gpu --disable-gpu-compositing --disable-accelerated-2d-canvas --disable-web-security",
    "start:debug": "electron . --enable-logging --log-level=2",
    "start:production": "cross-env NODE_ENV=production ELECTRON_DISABLE_HARDWARE_ACCELERATION=true electron .",
    "test:gpu": "electron . --disable-gpu-sandbox --disable-features=VizDisplayCompositor --log-level=1",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integrations",
    "test:mocks": "jest tests/mocks",
    "test:e2e": "jest tests/e2e",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose",
    "test:silent": "jest --silent",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test-quick": "node scripts/quick-test.js",
    "test:debug": "node --inspect-brk ./node_modules/.bin/jest --runInBand",
    "posttest": "npm run test:cleanup",
    "test:cleanup": "node scripts/test-cleanup.js",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,json,md}\"",
    "clean": "rimraf dist build coverage .cache",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "pack": "electron-builder --dir",
    "dist": "npm run build",
    "postinstall": "electron-builder install-app-deps",
    "setup": "node scripts/setup.js",
    "setup-user": "node scripts/setup-test-user.js",
    "db:init": "node scripts/init-db.js",
    "db:migrate": "node scripts/migrate-db.js",
    "db:seed": "node scripts/seed-db.js",
    "validate": "node scripts/validate-setup.js",
    "quality-control": "npm start",
    "quality-control:dev": "npm run dev"
  },
  "keywords": [
    "electron",
    "rfid",
    "qr-code",
    "quality-control",
    "qualitätskontrolle",
    "scanner",
    "mssql",
    "dual-scan",
    "shirtful"
  ],
  "author": "Shirtful Development Team",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "dotenv": "^16.4.5",
    "electron": "^28.1.0",
    "mssql": "^10.0.2",
    "node-hid": "^2.1.2"
  },
  "devDependencies": {
    "@babel/core": "^7.23.7",
    "@babel/preset-env": "^7.23.7",
    "babel-jest": "^29.7.0",
    "cross-env": "^7.0.3",
    "electron-builder": "^24.9.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest": "^27.6.3",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "jest-watch-typeahead": "^2.2.2",
    "jsdom": "^23.2.0",
    "mock-fs": "^5.2.0",
    "prettier": "^3.2.4",
    "rimraf": "^5.0.5"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "qualitaetskontrolle": {
    "mode": "dual-scan",
    "features": {
      "dualScanning": true,
      "automaticSessionEnd": true,
      "duplicateDetection": true,
      "rfidSessionManagement": true,
      "parallelSessions": true,
      "processingTimeTracking": true
    },
    "limits": {
      "maxParallelSessions": 15,
      "maxUsersPerSession": 1,
      "qrScanCooldown": 1000,
      "duplicateProtection": true
    },
    "workflow": {
      "firstScan": "quality_check_start",
      "secondScan": "quality_check_complete",
      "sessionEndAfterSecondScan": true,
      "newSessionAfterEnd": true
    }
  },
  "build": {
    "appId": "com.shirtful.qualitaetskontrolle",
    "productName": "Qualitätskontrolle RFID QR",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "rfid/**/*",
      "db/**/*",
      "node_modules/**/*",
      "!node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!node_modules/*.d.ts",
      "!node_modules/.bin",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!.editorconfig",
      "!**/._*",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,.gitignore,.gitattributes}",
      "!**/{__pycache__,thumbs.db,.flowconfig,.idea,.vs,.nyc_output}",
      "!**/{appveyor.yml,.travis.yml,circle.yml}",
      "!**/{npm-debug.log,yarn.lock,.yarn-integrity,.yarn-metadata.json}"
    ],
    "extraResources": [
      {
        "from": ".env.example",
        "to": ".env.example"
      },
      {
        "from": "README.md",
        "to": "README.md"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Qualitätskontrolle RFID QR",
      "menuCategory": "Shirtful"
    }
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup/jest.setup.js"
    ],
    "testMatch": [
      "<rootDir>/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "main.js",
      "db/**/*.js",
      "rfid/**/*.js",
      "!**/node_modules/**",
      "!**/tests/**"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "verbose": true,
    "testTimeout": 30000
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2021": true,
      "jest": true
    },
    "extends": [
      "eslint:recommended",
      "prettier"
    ],
    "parserOptions": {
      "ecmaVersion": 2021,
      "sourceType": "module"
    },
    "rules": {
      "no-unused-vars": [
        "warn",
        {
          "argsIgnorePattern": "^_"
        }
      ],
      "no-console": "off"
    },
    "globals": {
      "electronAPI": "readonly",
      "qualityUtils": "readonly",
      "utils": "readonly",
      "config": "readonly",
      "errorHandler": "readonly"
    }
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "tabWidth": 4,
    "trailingComma": "es5",
    "printWidth": 100
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shirtful/qualitaetskontrolle-rfid-qr.git"
  },
  "bugs": {
    "url": "https://github.com/shirtful/qualitaetskontrolle-rfid-qr/issues"
  },
  "homepage": "https://github.com/shirtful/qualitaetskontrolle-rfid-qr#readme"
}