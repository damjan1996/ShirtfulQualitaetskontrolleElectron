{
  "name": "qualitaetskontrolle-rfid-qr",
  "version": "1.0.0",
  "description": "RFID QR Qualitätskontrolle - Doppel-Scan System für Shirtful",
  "main": "main.js",
  "homepage": "https://github.com/shirtful/qualitaetskontrolle-rfid-qr#readme",
  "scripts": {
    "start": "electron .",
    "dev": "cross-env NODE_ENV=development electron .",
    "debug": "cross-env NODE_ENV=development electron . --inspect=9229",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:quick": "jest --testNamePattern=\"Quick\"",
    "test:db": "node scripts/test-database.js",
    "test:rfid": "node scripts/test-rfid.js",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --testNamePattern=\"Integration\"",
    "test:unit": "jest --testNamePattern=\"Unit\"",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,json,md}\"",
    "clean": "rimraf dist build coverage .cache",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "pack": "electron-builder --dir",
    "dist": "npm run build",
    "postinstall": "electron-builder install-app-deps",
    "setup": "node scripts/setup.js",
    "db:init": "node scripts/init-db.js",
    "db:migrate": "node scripts/migrate-db.js",
    "db:seed": "node scripts/seed-db.js",
    "validate": "node scripts/validate-setup.js",
    "multi-user": "npm start -- --multi-user",
    "single-user": "npm start -- --single-user"
  },
  "keywords": [
    "electron",
    "rfid",
    "qr-code",
    "qualitaetskontrolle",
    "quality-control",
    "scanner",
    "mssql",
    "multi-user",
    "parallel-sessions",
    "double-scan"
  ],
  "author": "Shirtful Development Team",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "dotenv": "^16.4.5",
    "electron": "^28.1.0",
    "mssql": "^10.0.2",
    "node-hid": "^2.1.2"
  },
  "devDependencies": {
    "@babel/core": "^7.23.7",
    "@babel/preset-env": "^7.23.7",
    "babel-jest": "^29.7.0",
    "cross-env": "^7.0.3",
    "electron-builder": "^24.9.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest": "^27.6.3",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "jest-watch-typeahead": "^2.2.2",
    "jsdom": "^23.2.0",
    "mock-fs": "^5.2.0",
    "prettier": "^3.2.4",
    "rimraf": "^5.0.5"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "qualitaetskontrolle": {
    "mode": "multi-user",
    "features": {
      "doubleScanLogic": true,
      "autoSessionEnd": true,
      "parallelSessions": true,
      "sessionRestart": true,
      "multiUserQRScanning": true,
      "rfidSessionManagement": true,
      "duplicateDetection": true,
      "gpuOptimized": true
    },
    "limits": {
      "maxParallelSessions": 15,
      "maxUsersPerSession": 1,
      "qrScanCooldown": 2000,
      "maxScansPerBox": 2,
      "duplicateErrorOnThirdScan": true
    }
  },
  "build": {
    "appId": "com.shirtful.qualitaetskontrolle",
    "productName": "Qualitätskontrolle RFID QR",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "rfid/**/*",
      "db/**/*",
      "node_modules/**/*",
      "!node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!node_modules/*.d.ts",
      "!node_modules/.bin",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!.editorconfig",
      "!**/._*",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,.gitignore,.gitattributes}",
      "!**/{__pycache__,thumbs.db,.flowconfig,.idea,.vs,.nyc_output}",
      "!**/{appveyor.yml,.travis.yml,circle.yml}",
      "!**/{npm-debug.log,yarn.lock,.yarn-integrity,.yarn-metadata.json}"
    ],
    "extraMetadata": {
      "qualitaetskontrolle": {
        "version": "1.0.0",
        "mode": "multi-user",
        "description": "Qualitätskontrolle mit Doppel-Scan-Logik - GPU optimiert"
      }
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Qualitätskontrolle RFID QR",
      "menuCategory": "Shirtful Tools"
    },
    "mac": {
      "category": "public.app-category.business",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "category": "Office",
      "icon": "assets/icon.png"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/shirtful/qualitaetskontrolle-rfid-qr.git"
  },
  "bugs": {
    "url": "https://github.com/shirtful/qualitaetskontrolle-rfid-qr/issues"
  },
  "config": {
    "qualitaetskontrolle": {
      "defaultMode": "multi-user",
      "enableParallelSessions": true,
      "enableSessionRestart": true,
      "enableDoubleScan": true,
      "maxConcurrentUsers": 15,
      "sessionTimeoutHours": 8,
      "autoLogoutDisabled": true,
      "gpuOptimizationsEnabled": true
    }
  }
}